{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# MacOS 에서만 실행

PACKAGES=(
    bat
    chezmoi
    curl
    fnm
    fzf
    gh
    git
    git-delta
    lazygit
    mas
    neovim
    openjdk@17
    ripgrep
    starship
    yarn
    zoxide
    zsh-autosuggestions
    zsh-syntax-highlighting
)

CASKS=(
    bettertouchtool
    font-hack-nerd-font
    ghostty
    karabiner-elements
    maccy
)

MAS_APPS=(
    "441258766"  # Magnet
)

# Homebrew가 없으면 설치
if test ! $(which brew); then
    printf '\n\n\e[33mHomebrew not found. \e[0mInstalling Homebrew...'
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
else
    printf '\n\n\e[0mHomebrew found. Continuing...'
fi

printf '\nInitiating Homebrew update...\n'
brew update

printf '\nInstalling packages...\n'
for pkg in "${PACKAGES[@]}"; do
    brew list "$pkg" &>/dev/null && printf "  [skip] $pkg already installed\n" || brew install "$pkg"
done

printf '\n\nRemoving out of date packages...\n'
brew cleanup

printf '\n\nInstalling cask apps...\n'
for cask in "${CASKS[@]}"; do
    brew list --cask "$cask" &>/dev/null && printf "  [skip] $cask already installed\n" || brew install --cask "$cask"
done

printf '\n\nInstalling App Store apps...\n'
for app_id in "${MAS_APPS[@]}"; do
    mas list | grep -q "^$app_id" && printf "  [skip] $app_id already installed\n" || mas install "$app_id"
done

# SpaceVim 설치
if [ ! -d "$HOME/.SpaceVim" ]; then
    printf '\n\nInstalling SpaceVim...\n'
    curl -sLf https://spacevim.org/install.sh | bash
else
    printf '\n\nSpaceVim already installed. Skipping...\n'
fi

{{ end -}}
