# Zsh 옵션
setopt AUTO_CD

# Completion 시스템 초기화
autoload -Uz compinit && compinit

alias c="claude"
alias cc="claude --continue"
alias ccd="claude --continue --dangerously-skip-permissions"
# Aliases
alias vim="nvim"
alias vi="nvim"

alias lg="lazygit"

# Git aliases
alias gst="git status"
alias gsta="git stash"
alias gstp="git stash pop"
alias gstl="git stash list"
alias gstd="git stash drop"
alias gp="git push"
alias gpf!="git push --force"
alias glog="git log --oneline --decorate --graph"
alias gloga="git log --oneline --decorate --graph --all"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gcmsg="git commit -m"
alias gl="git pull"
alias grbi="git rebase -i"

fs() {
 rg "" --line-number | fzf \
    --delimiter ':' \
    --preview 'bat --color=always --highlight-line {2} {1}' \
    --preview-window '+{2}-/2'
}
ff() {
 fzf --preview 'bat --color=always {}'
}
gd() {
  git diff "${1:-master}..HEAD" "${@:2}" ":(exclude)package-lock.json" ":(exclude)*.lock"
}
gwa() { git worktree add -b "$1" "../$1"; }
gwr() { git worktree remove "../$1" && git branch -D "$1"; }

export EDITOR=/opt/homebrew/bin/nvim

export JAVA_HOME="/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
export ANDROID_HOME=~/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools

export PATH="$HOME/.local/bin:$PATH"

# fzf
source <(fzf --zsh)

# Starship prompt
eval "$(starship init zsh)"

# zoxide (smart cd)
eval "$(zoxide init zsh)"

# mise (version manager)
eval "$(mise activate zsh)"

# Autosuggestions
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# 환경변수 로드
set -a
source ~/.env.local
set +a

# Work 환경 설정
test -e "${HOME}/.zshrc.work" && source "${HOME}/.zshrc.work"

# Syntax highlighting (반드시 마지막에 로드)
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
